meta {
  name: Services - list all
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/services
}

assert {
  res.status: eq 200
}

tests {
  test("returns an array", function () {
    expect(res.body).to.be.an("array");
  });

  test("services carry active and source fields", function () {
    if (res.body.length > 0) {
      expect(res.body[0]).to.have.property("active");
      expect(res.body[0]).to.have.property("source");
    }
  });
}
